<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Administración MiniStore</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body class="admin-body">
    <div class="admin-shell">
        <aside class="admin-sidebar">
            <a class="admin-brand" asp-controller="Admin" asp-action="Index">
                <img src="~/ministore/images/main-logo.png" alt="MiniStore" />
                <span>Administración</span>
            </a>

            <nav class="admin-nav" aria-label="Navegación de administración">
                <span class="admin-nav-title">Catálogo</span>
                <a class="admin-nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
                   asp-controller="Admin" asp-action="Index">
                    <span class="admin-nav-icon">⌂</span>
                    Dashboard
                </a>
                <a class="admin-nav-link @((ViewContext.RouteData.Values["action"]?.ToString() is "Productos" or "GuardarProducto") ? "active" : "")"
                   asp-controller="Admin" asp-action="Productos">
                    <span class="admin-nav-icon">□</span>
                    Productos
                </a>
            </nav>

            <div class="admin-sidebar-footer">
                <span>Sesión administrativa</span>
                <strong>@Context.Session.GetString("Nombre")</strong>
                <a asp-controller="Account" asp-action="Salir">Cerrar sesión</a>
            </div>
        </aside>

        <div class="admin-main">
            <header class="admin-topbar">
                <button class="admin-menu-button" type="button" aria-label="Abrir menú" data-admin-menu>
                    ☰
                </button>
                <div>
                    <span class="admin-eyebrow">MiniStore</span>
                    <strong>Panel de Administrador</strong>
                </div>
                <a class="admin-store-link" asp-controller="Home" asp-action="Index">Ver tienda</a>
            </header>

            <main class="admin-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.querySelector("[data-admin-menu]")?.addEventListener("click", () => {
            document.querySelector(".admin-sidebar")?.classList.toggle("open");
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
