<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MiniStore</title>
    <link rel="stylesheet" href="~/ministore/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/ministore/style.css" />
    <link rel="stylesheet" href="~/ministore/css/auth.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Jost:wght@300;400;500;600;700&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
</head>
<body class="auth-page-body">
    <header id="header" class="site-header position-fixed text-black bg-light auth-header">
        <nav class="navbar navbar-expand-lg px-3 py-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <img src="~/ministore/images/main-logo.png" class="logo" alt="MiniStore logo" />
                </a>
                <button class="navbar-toggler d-flex d-lg-none order-3 p-2" type="button" data-bs-toggle="collapse" data-bs-target="#authNavbar" aria-controls="authNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse justify-content-end" id="authNavbar">
                    <ul class="navbar-nav text-uppercase align-items-lg-center gap-lg-3">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Login" ? "active" : "")" asp-controller="Account" asp-action="Login">Login</a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-medium btn-dark text-uppercase btn-rounded-none auth-nav-btn" asp-controller="Account" asp-action="Register">Register</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="auth-main">
        @RenderBody()
    </main>

    <footer id="footer-bottom" class="auth-footer">
        <div class="container">
            <div class="row d-flex flex-wrap justify-content-between align-items-center">
                <div class="col-md-6">
                    <p class="mb-0">MiniStore experience for your project.</p>
                </div>
                <div class="col-md-6 text-md-end">
                    <a asp-controller="Account" asp-action="Login" class="me-4">Login</a>
                    <a asp-controller="Account" asp-action="Register">Create account</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/ministore/js/jquery-1.11.0.min.js"></script>
    <script src="~/ministore/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
