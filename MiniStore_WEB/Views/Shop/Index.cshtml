@model List<ProductoModel>

@{
    ViewData["Title"] = "Tienda";
    var categorias = ViewBag.Categorias as List<CategoriaModel>
        ?? new List<CategoriaModel>();
    int? categoriaSeleccionada = ViewBag.CategoriaSeleccionada;
}

<section class="mb-5">
    <div class="text-center mb-5">
        <h1 class="display-5 text-uppercase">Nuestros productos</h1>
        <p>Explorá el catálogo de MiniStore.</p>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger">@ViewBag.Error</div>
    }

    <form asp-controller="Shop"
          asp-action="Index"
          method="get"
          class="row g-3 mb-5">
        <div class="col-md-9">
            <label for="categoria" class="form-label">Categoría</label>
            <select id="categoria" name="categoria" class="form-select">
                <option value="">Todas las categorías</option>
                @foreach (var categoria in categorias)
                {
                    if (categoriaSeleccionada == categoria.Consecutivo)
                    {
                        <option value="@categoria.Consecutivo" selected>
                            @categoria.NombreCategoria
                        </option>
                    }
                    else
                    {
                        <option value="@categoria.Consecutivo">
                            @categoria.NombreCategoria
                        </option>
                    }
                }
            </select>
        </div>
        <div class="col-md-3 d-flex align-items-end">
            <button type="submit" class="btn btn-dark w-100">Filtrar</button>
        </div>
    </form>

    @if (Model.Count == 0)
    {
        <div class="alert alert-info">
            No se encontraron productos disponibles.
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var producto in Model)
            {
                var rutaImagen = string.IsNullOrWhiteSpace(producto.Imagen)
                    ? Url.Content("~/ministore/images/product-item1.jpg")
                    : Url.Content($"~/ministore/images/{producto.Imagen.TrimStart('/', '\\')}");

                <div class="col-lg-3 col-md-6">
                    <article class="card border-0 shadow-sm h-100">
                        <img src="@rutaImagen"
                             alt="@producto.Nombre"
                             class="card-img-top"
                             style="height: 280px; object-fit: cover;"
                             onerror="this.onerror=null;this.src='@Url.Content("~/ministore/images/product-item1.jpg")';" />
                        <div class="card-body d-flex flex-column">
                            <small class="text-muted text-uppercase">
                                @producto.NombreCategoria
                            </small>
                            <h2 class="h5 mt-2">@producto.Nombre</h2>
                            <p>@producto.Descripcion</p>
                            <p class="mb-2">Stock: @producto.Stock</p>
                            <p class="text-primary fs-5">
                                ₡@producto.Precio.ToString("N2")
                            </p>
                            <a asp-controller="Shop"
                               asp-action="Details"
                               asp-route-id="@producto.Consecutivo"
                               class="btn btn-dark mt-auto">
                                Ver detalle
                            </a>
                        </div>
                    </article>
                </div>
            }
        </div>
    }
</section>
