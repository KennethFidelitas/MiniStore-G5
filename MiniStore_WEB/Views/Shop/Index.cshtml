@model List<ProductoModel>

@{
    ViewData["Title"] = "Tienda";
    var categorias = ViewBag.Categorias as List<CategoriaModel>
        ?? new List<CategoriaModel>();
    int? categoriaSeleccionada = ViewBag.CategoriaSeleccionada;
}

<section class="product-store padding-large">
    <div class="container">

        <div class="text-center mb-5">
            <h1 class="display-7 text-uppercase text-dark">Nuestros productos</h1>
            <p>Explorá el catálogo de MiniStore.</p>
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">@ViewBag.Error</div>
        }

        <form asp-controller="Shop"
              asp-action="Index"
              method="get"
              class="row g-3 mb-5">
            <div class="col-md-9">
                <label for="categoria" class="form-label">Categoría</label>
                <select id="categoria" name="categoria" class="form-select">
                    <option value="">Todas las categorías</option>
                    @foreach (var categoria in categorias)
                    {
                        if (categoriaSeleccionada == categoria.Consecutivo)
                        {
                            <option value="@categoria.Consecutivo" selected>
                                @categoria.NombreCategoria
                            </option>
                        }
                        else
                        {
                            <option value="@categoria.Consecutivo">
                                @categoria.NombreCategoria
                            </option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <button type="submit" class="btn btn-medium btn-dark text-uppercase w-100">Filtrar</button>
            </div>
        </form>

        @if (Model.Count == 0)
        {
            <div class="alert alert-info">
                No se encontraron productos disponibles.
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var producto in Model)
                {
                    var rutaImagen = string.IsNullOrWhiteSpace(producto.Imagen)
                        ? Url.Content("~/ministore/images/product-item1.jpg")
                        : Url.Content($"~/ministore/images/{producto.Imagen.TrimStart('/', '\\')}");

                    <div class="col-lg-3 col-md-6">
                        <div class="product-card position-relative">
                            <a asp-controller="Shop" asp-action="Details" asp-route-id="@producto.Consecutivo">
                                <div class="image-holder">
                                    <img src="@rutaImagen"
                                         alt="@producto.Nombre"
                                         class="img-fluid"
                                         onerror="this.onerror=null;this.src='@Url.Content("~/ministore/images/product-item1.jpg")';" />
                                </div>
                            </a>
                            <div class="cart-concern position-absolute">
                                <div class="cart-button d-flex">
                                    <a asp-controller="Shop" asp-action="Details" asp-route-id="@producto.Consecutivo"
                                       class="btn btn-medium btn-black">
                                        Ver detalle
                                        <svg class="cart-outline"><use xlink:href="#cart-outline"></use></svg>
                                    </a>
                                </div>
                            </div>
                            <div class="card-detail pt-3">
                                <small class="text-muted text-uppercase">@producto.NombreCategoria</small>
                                <h3 class="card-title text-uppercase mt-1">
                                    <a asp-controller="Shop" asp-action="Details" asp-route-id="@producto.Consecutivo">@producto.Nombre</a>
                                </h3>
                                <p class="mb-1 small text-muted">Stock: @producto.Stock</p>
                                <span class="item-price text-primary">₡@producto.Precio.ToString("N2")</span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>