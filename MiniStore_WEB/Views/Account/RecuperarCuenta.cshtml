@model UsuarioModel

@{
    Layout = "_MiniStoreAuthLayout";
    ViewData["Title"] = "RecuperarCuenta";
}

<section class="auth-shell">
    <div class="container">
        <div class="row align-items-center g-0 auth-card-wrap">

            @* ── PANEL IZQUIERDO: showcase ── *@
            <div class="col-lg-6">
                <div class="auth-showcase">
                    <span class="auth-kicker">Recuperación de cuentas</span>
                    <h1>Recupera tu cuenta en segundos.</h1>
                    <p>
                        Introduce tu correo electrónico y te enviaremos un enlace seguro para restablecer tu contraseña y volver a comprar de inmediato.
                    </p>

                    <div class="auth-feature-grid">
                        <div class="auth-feature-box">
                            <h3>Restablecimiento seguro</h3>
                            <p>Su enlace caduca en 30 minutos para su protección.</p>
                        </div>
                        <div class="auth-feature-box">
                            <h3>Acceso rápido</h3>
                            <p>Volverás a tus pedidos y lista de deseos enseguida.</p>
                        </div>
                    </div>

                    <div class="auth-showcase-panel">
                        <span class="auth-panel-label">Consejo de seguridad</span>
                        <strong>Nunca compartas tu enlace de restablecimiento</strong>
                        <p>MiniStore nunca te pedirá tu contraseña ni tu enlace por correo electrónico o chat.</p>
                    </div>
                </div>
            </div>

            @* ── PANEL DERECHO: formulario ── *@
            <div class="col-lg-6">
                <div class="auth-form-panel">
                    <div class="auth-form-header">
                        <span class="auth-form-kicker">Restablecimiento de contraseña</span>
                        <h2>Olvidaste tu contraseña?</h2>
                        <p>Introduce el correo electrónico asociado a tu cuenta y te enviaremos el enlace de recuperación.</p>
                    </div>
                    @if (!string.IsNullOrEmpty(ViewBag.Mensaje))
                    {
                        <div class="alert @(ViewBag.Mensaje.ToString().Contains("Te enviamos") ? "alert-success" : "alert-danger") alert-dismissible fade show mb-4" role="alert">
                            @ViewBag.Mensaje
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
                        </div>
                    }
                    <form class="auth-form" asp-controller="Account" asp-action="RecuperarCuenta" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="auth-input-group">
                            <label asp-for="CorreoElectronico"></label>
                            <input asp-for="CorreoElectronico" class="form-control" placeholder="nombre@ejemplo.com" autocomplete="email" />
                            <span asp-validation-for="CorreoElectronico" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-medium btn-dark text-uppercase btn-rounded-none auth-submit">
                            Enviar enlace de restablecimiento
                        </button>
                    </form>

                    <div class="auth-divider"><span>o</span></div>

                    <p class="auth-switch">
                        Recuerdas tu contraseña?
                        <a asp-controller="Account" asp-action="Login">Volver al inicio de sesión</a>
                    </p>

                    <p class="auth-switch">
                        No tienes una cuenta?
                        <a asp-controller="Account" asp-action="Register">Crea una</a>
                    </p>
                </div>
            </div>

        </div>
    </div>
</section>
