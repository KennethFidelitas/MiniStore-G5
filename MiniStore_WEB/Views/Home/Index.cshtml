@model List<ProductoModel>

@{
    ViewData["Title"] = "Inicio";
}

<section id="billboard" class="position-relative overflow-hidden bg-light-blue">
    <div class="swiper main-swiper">
        <div class="swiper-wrapper">
            <div class="swiper-slide">
                <div class="container">
                    <div class="row d-flex align-items-center">
                        <div class="col-md-6">
                            <div class="banner-content">
                                <h1 class="display-2 text-uppercase text-dark pb-5">Tecnología para tu día a día</h1>
                                <a asp-controller="Shop" asp-action="Index"
                                   class="btn btn-medium btn-dark text-uppercase btn-rounded-none">Ver catálogo</a>
                            </div>
                        </div>
                        <div class="col-md-5">
                            <div class="image-holder">
                                <img src="~/ministore/images/banner-image.png" alt="MiniStore" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="swiper-icon swiper-arrow swiper-arrow-prev">
        <svg class="chevron-left"><use xlink:href="#chevron-left" /></svg>
    </div>
    <div class="swiper-icon swiper-arrow swiper-arrow-next">
        <svg class="chevron-right"><use xlink:href="#chevron-right" /></svg>
    </div>
</section>


<section id="company-services" class="padding-large">
    <div class="container">
        <div class="row">
            <div class="col-lg-3 col-md-6 pb-3">
                <div class="icon-box d-flex">
                    <div class="icon-box-icon pe-3 pb-3">
                        <svg class="cart-outline"><use xlink:href="#cart-outline" /></svg>
                    </div>
                    <div class="icon-box-content">
                        <h3 class="card-title text-uppercase text-dark">Envío gratis</h3>
                        <p>En todos los pedidos dentro del país.</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6 pb-3">
                <div class="icon-box d-flex">
                    <div class="icon-box-icon pe-3 pb-3">
                        <svg class="quality"><use xlink:href="#quality" /></svg>
                    </div>
                    <div class="icon-box-content">
                        <h3 class="card-title text-uppercase text-dark">Garantía de calidad</h3>
                        <p>Productos verificados antes de cada envío.</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6 pb-3">
                <div class="icon-box d-flex">
                    <div class="icon-box-icon pe-3 pb-3">
                        <svg class="price-tag"><use xlink:href="#price-tag" /></svg>
                    </div>
                    <div class="icon-box-content">
                        <h3 class="card-title text-uppercase text-dark">Ofertas diarias</h3>
                        <p>Descuentos nuevos cada semana.</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6 pb-3">
                <div class="icon-box d-flex">
                    <div class="icon-box-icon pe-3 pb-3">
                        <svg class="shield-plus"><use xlink:href="#shield-plus" /></svg>
                    </div>
                    <div class="icon-box-content">
                        <h3 class="card-title text-uppercase text-dark">Pago 100% seguro</h3>
                        <p>Tus datos siempre protegidos.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>


<section id="featured-products" class="product-store position-relative padding-large no-padding-top">
    <div class="container">
        <div class="row">
            <div class="display-header d-flex justify-content-between pb-3">
                <h2 class="display-7 text-dark text-uppercase">Productos destacados</h2>
                <div class="btn-right">
                    <a asp-controller="Shop" asp-action="Index" class="btn btn-medium btn-normal text-uppercase">Ir a la tienda</a>
                </div>
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">@ViewBag.Error</div>
            }

            @if (Model == null || Model.Count == 0)
            {
                <div class="alert alert-info">No hay productos disponibles en este momento.</div>
            }
            else
            {
                <div class="row g-4">
                    @foreach (var producto in Model.Take(8))
                    {
                        var rutaImagen = string.IsNullOrWhiteSpace(producto.Imagen)
                            ? Url.Content("~/ministore/images/product-item1.jpg")
                            : Url.Content($"~/ministore/images/{producto.Imagen.TrimStart('/', '\\')}");

                        <div class="col-lg-3 col-md-6">
                            <div class="product-card position-relative">
                                <a asp-controller="Shop" asp-action="Details" asp-route-id="@producto.Consecutivo">
                                    <div class="image-holder">
                                        <img src="@rutaImagen" alt="@producto.Nombre" class="img-fluid"
                                             onerror="this.onerror=null;this.src='@Url.Content("~/ministore/images/product-item1.jpg")';" />
                                    </div>
                                </a>
                                <div class="cart-concern position-absolute">
                                    <div class="cart-button d-flex">
                                        <a asp-controller="Shop" asp-action="Details" asp-route-id="@producto.Consecutivo"
                                           class="btn btn-medium btn-black">
                                            Ver detalle
                                            <svg class="cart-outline"><use xlink:href="#cart-outline"></use></svg>
                                        </a>
                                    </div>
                                </div>
                                <div class="card-detail d-flex justify-content-between align-items-baseline pt-3">
                                    <h3 class="card-title text-uppercase">
                                        <a asp-controller="Shop" asp-action="Details" asp-route-id="@producto.Consecutivo">@producto.Nombre</a>
                                    </h3>
                                    <span class="item-price text-primary">₡@producto.Precio.ToString("N2")</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</section>