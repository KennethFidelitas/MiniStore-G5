@model List<ProductoModel>

@{
    ViewData["Title"] = "Inicio";
}

<section class="rounded-3 bg-light p-5 mb-5">
    <div class="row align-items-center">
        <div class="col-lg-7">
            <h1 class="display-3 text-uppercase">Tecnología para tu día a día</h1>
            <p class="lead">Descubrí los productos disponibles en MiniStore.</p>
            <a asp-controller="Shop"
               asp-action="Index"
               class="btn btn-dark btn-lg text-uppercase">
                Ver catálogo
            </a>
        </div>
        <div class="col-lg-5 d-none d-lg-block text-center">
            <img src="~/ministore/images/banner-image.png"
                 alt="Productos MiniStore"
                 class="img-fluid" />
        </div>
    </div>
</section>

<section class="mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-uppercase mb-0">Productos destacados</h2>
        <a asp-controller="Shop" asp-action="Index" class="text-dark">
            Ver todos
        </a>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger">@ViewBag.Error</div>
    }

    @if (Model.Count == 0)
    {
        <div class="alert alert-info">
            No hay productos disponibles en este momento.
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var producto in Model)
            {
                var rutaImagen = string.IsNullOrWhiteSpace(producto.Imagen)
                    ? Url.Content("~/ministore/images/product-item1.jpg")
                    : Url.Content($"~/ministore/images/{producto.Imagen.TrimStart('/', '\\')}");

                <div class="col-lg-3 col-md-6">
                    <article class="card border-0 shadow-sm h-100">
                        <img src="@rutaImagen"
                             alt="@producto.Nombre"
                             class="card-img-top"
                             style="height: 260px; object-fit: cover;"
                             onerror="this.onerror=null;this.src='@Url.Content("~/ministore/images/product-item1.jpg")';" />
                        <div class="card-body d-flex flex-column">
                            <small class="text-muted text-uppercase">
                                @producto.NombreCategoria
                            </small>
                            <h3 class="h5 mt-2">@producto.Nombre</h3>
                            <p class="text-primary fs-5">
                                ₡@producto.Precio.ToString("N2")
                            </p>
                            <a asp-controller="Shop"
                               asp-action="Details"
                               asp-route-id="@producto.Consecutivo"
                               class="btn btn-outline-dark mt-auto">
                                Ver detalle
                            </a>
                        </div>
                    </article>
                </div>
            }
        </div>
    }
</section>
